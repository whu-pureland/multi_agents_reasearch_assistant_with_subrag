# LLM (OpenAI-compatible)
# Providers: openai | moonshot | deepseek (or set LLM_BASE_URL for any compatible endpoint)
LLM_PROVIDER=moonshot
LLM_API_KEY=
LLM_MODEL=kimi-k2.5
LLM_BASE_URL=https://api.moonshot.cn/v1

# Provider-specific keys (optional; used when LLM_API_KEY is empty)
MOONSHOT_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Embeddings (for RAG)
# Providers: openai (OpenAI-compatible) | local (sentence-transformers / Hugging Face)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# Backward-compatible OpenAI envs (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=

# Web search provider: duckduckgo | tavily | disabled
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_SEARCH_DEPTH=basic
